rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Список администраторов. Документы сюда добавляются вручную в консоли Firebase —
    // ни один клиент не может сам себя сделать администратором.
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Общие данные ICON FINANCE (rows / expenses / balances) — по одному документу
    // на каждый набор. Читать может любой авторизованный пользователь,
    // менять — только администратор.
    match /cashflow/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
